package elements;

import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.Input.Keys;
import com.badlogic.gdx.scenes.scene2d.Stage;
import com.badlogic.gdx.scenes.scene2d.ui.Label;

import game.Parametros;
import managers.AudioManager;
import managers.ResourceManager;
import screens.GameScreen;

public class Gatas extends Ghosts {
	
	private int nDialog = 0;

	public Gatas(float x, float y, Stage s, GameScreen lvl) {
		super(x, y, s, lvl);
		this.loadFullAnimation("maps/images/tinaMina.png", 1, 1, 1, false);
		
		this.lvl = lvl;
		this.setEnabled(false);
		
	}
	
	@Override
	public void act(float delta) {
		super.act(delta);
		
		if(Parametros.cats) {
			this.setEnabled(true);
		}
		if(this.getEnabled()) {
			dialog();
			
			if(this.overlaps(this.lvl.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E)) {
				
				if(!Parametros.catsKey) {
					this.lvl.player.stayStill = true;
					AudioManager.playSound("audio/sounds/npcs/Gatas.mp3");
					this.nDialog = 1;
				} else if(Parametros.catsKey) {
					this.lvl.player.stayStill = true;
					AudioManager.playSound("audio/sounds/npcs/Gatas.mp3");
					this.nDialog = 7;
				}
			}
		
		if(this.overlaps(this.lvl.player.sensor) && Gdx.input.isKeyJustPressed(Keys.SPACE)) {
			this.nDialog++;
			if(!Parametros.catsKey) {
				if(nDialog >= 6) {
					this.lvl.lblCats.setText("");
					this.lvl.dialogLabels.get("Jeremy").setText("");
					this.lvl.player.stayStill = false;
					Parametros.catsKey = true;
				}
			
			} else if(Parametros.catsKey) {
				if(nDialog >= 8) {
					catsDialogLbl.setText("");
					dialogLbl.setText("");
					this.lvl.player.stayStill = false;
					Parametros.catsKey = true;
				}
			}
			
		}
			
		}
		
	}
	
	private void dialog() {
		catsDialogLbl.setPosition(150, Parametros.getAltoPantalla()-Parametros.getAltoPantalla()/1.25f);
		dialogLbl.setPosition(150, Parametros.getAltoPantalla()-Parametros.getAltoPantalla()/1.25f);
		
		switch(nDialog) {
		case 1:
			catsDialogLbl.setText("Tina y Mina: °Provoc·bamos incendios!");
			break;
			
		case 2:
			catsDialogLbl.setText("Tina y Mina: °Hola Jeremy, cu·nto nos alegramos de verte!");
			break;
			
		case 3:
			catsDialogLbl.setText("Tina y Mina: °øNecesitas algo?!");
			break;
			
		case 4:
			catsDialogLbl.setText("");
			dialogLbl.setText("Jeremy: Dadles la llave que os dejÈ, la de la florecita naranja.");
			break;
			
		case 5:
			dialogLbl.setText("");
			catsDialogLbl.setText("Tina y Mina: °AquÌ tenÈis!");
			break;
			
		case 7:
			catsDialogLbl.setText("Tina y Mina: °Nos encanta pasar tiempo con Jeremy!");
			break;
			
		default: 
			catsDialogLbl.setText("");
			dialogLbl.setText("");
			break;
		}
	}

}
