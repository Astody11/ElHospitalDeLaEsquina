package elements;

import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.Input.Keys;
import com.badlogic.gdx.graphics.g2d.Animation;
import com.badlogic.gdx.graphics.g2d.TextureRegion;
import com.badlogic.gdx.scenes.scene2d.Stage;
import com.badlogic.gdx.scenes.scene2d.ui.Label;

import game.Parametros;
import managers.AudioManager;
import managers.ResourceManager;
import screens.GameScreen;

public class Jeremy extends Ghosts{

	private Animation<TextureRegion> dcha;
	private Animation<TextureRegion> izq;
	private int nDialog = 0;
	
	private Label infoLbl;
	
	public Jeremy(float x, float y, Stage s, GameScreen lvl) {
		super(x, y, s, lvl);
		izq = loadFullAnimation("npcs/JeremyFloatsT.png", 1, 10, 0.2f, true);
		dcha = loadFullAnimation("npcs/JeremyFloatsTDcha.png", 1, 10, 0.2f, true);
		this.setAnimation(izq);
		
		infoLbl = new Label("!", ResourceManager.npcMarcadorStyle);
		infoLbl.setPosition(this.getX() + this.getWidth()/2.5f, this.getY() + this.getHeight());
		s.addActor(infoLbl);
	}
	
	public void act(float delta) {
		super.act(delta);
		
		if(this.getEnabled()) {
			animations();
			dialog();
			
			if(this.overlaps(this.lvl.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E) && !this.lvl.player.stayStill) {
				
				if(Parametros.nivel == 243) {
					AudioManager.playSound("audio/sounds/npcs/Eey.mp3");
					this.lvl.player.stayStill = true;
					this.nDialog = 1;
				} else if(Parametros.nivel == 0) {
					AudioManager.playSound("audio/sounds/npcs/YAhoraQ.mp3");
					this.lvl.player.stayStill = true;
					this.nDialog = 8;
				}
				
			} 
			
			if(Parametros.ghostCompannion.equals("Jeremy")) {
				position();
				infoLbl.setText("");
			}
			
			if(Gdx.input.isKeyJustPressed(Keys.SPACE) && this.overlaps(this.lvl.player.sensor) && this.lvl.player.stayStill) {
				this.nDialog++;
				if(Parametros.nivel == 243) {
					if(nDialog >= 7) {
						this.lvl.dialogLabels.get("Jeremy").setText("");
						this.lvl.player.stayStill = false;
						Parametros.ghostCompannion = "Jeremy";
						Parametros.ghostPower = "Enemigos no te persiguen";
					}
					if(nDialog == 7) {
						AudioManager.playSound("audio/sounds/npcs/PorFin.mp3");
					}
				} else if(Parametros.nivel == 0) {
					if(nDialog >= 9) {
						this.lvl.dialogLabels.get("Jeremy").setText("");
						this.lvl.player.stayStill = false;
					}
				}
				
				
			
			}
			
			if((Parametros.nivel == 243 && Parametros.cats) || (Parametros.nivel == 0 && !Parametros.cats && !Parametros.ghostCompannion.equals("Jeremy"))) {
				this.setEnabled(false);
			}
			
			
			if(this.overlaps(this.lvl.player.sensor)) {
				infoLbl.setText("'E'");
			} else {
				if(Parametros.cats) {
					infoLbl.setText("");
				} else if(!Parametros.cats){
					if(Parametros.ghostCompannion.equals("Jeremy")) {
						infoLbl.setText("");
					} else if (Parametros.nivel != 0){
						infoLbl.setText("!");
					}
				}
				//this.lvl.dialogLabels.get("Jeremy").setText("");
			}
		}
	}
	
	private void dialog() {
		
		switch(nDialog) {
		case 1:
			this.lvl.dialogLabels.get("Jeremy").setText("Jeremy: Si me escoltáis hasta la cocina os daré la llave de la habitación 204.");
			break;
		case 2:
			this.lvl.dialogLabels.get("Jeremy").setText("");
			this.lvl.lblSophie.setText("Sophie: Está bien, żcómo se llega hasta la cocina?");
			break;
			
		case 3:
			this.lvl.lblSophie.setText("");
			this.lvl.dialogLabels.get("Jeremy").setText("Jeremy: Es la planta -1, para llegar hay que coger el ascensor y pulsar '0'.");
			break;
			
		case 4:
			this.lvl.dialogLabels.get("Jeremy").setText("");
			this.lvl.lblSophie.setText("Sophie: żEl '0'? żPor qué no el '-1'?");
			break;
		case 5:
			this.lvl.lblSophie.setText("");
			this.lvl.dialogLabels.get("Jeremy").setText("Jeremy: A la hora de programar el panel del ascensor, que el jugador pulsara '-' y luego el '1'"
					+ "\n" + "estaba dando muchos problemas de funcionalidad.");
			break;
			
		case 6:
			this.lvl.dialogLabels.get("Jeremy").setText("");
			this.lvl.lblSophie.setText("Sophie: Ajá...");
			break;
			
		case 8:
			this.lvl.dialogLabels.get("Jeremy").setText("Jeremy: Son las únicas que comprenden mi jodido sufrimiento en esta eterna y miserable muerte.");
			break;
			
			default:
				this.lvl.lblSophie.setText("");
				this.lvl.dialogLabels.get("Jeremy").setText("Pepe");
				break;
		}
	}
	
	
	
	private void animations() {
		if(Parametros.ghostCompannion.equals("Jeremy")) {
			if(this.lvl.player.direction == 1) {
				this.setAnimation(dcha);
			} else {
				this.setAnimation(izq);
			}
		} else {
			this.setAnimation(izq);
		}
		
		
	}

}
