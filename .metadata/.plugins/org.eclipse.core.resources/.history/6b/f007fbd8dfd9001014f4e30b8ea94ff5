	public class ActorComparator implements Comparator<Actor> {

		@Override
		public int compare(Actor a, Actor b) {
			if(a.getY() == b.getY()) {
				return 0;
			}
			
			if(a.getY() > b.getY()) {
				return -1;
			}
			return 1;
		}
		
	}
	
