	//Bucle de juego, EL BUCLE PRINCIPAL. 3 COSAS: SE PINTAN LOS ELEMENTOS, SE LEEN LAS ENTRADAS(los controles), SE ACTUALIZA LAS PANTALLAS
	@Override
	public void render(float delta) { //delta: Tiempo de juego transcurrido desde q se ejecutó el último frame
		
		super.render(delta);
	     mainStage.act(); //ACTUAR O ACTUALIZAR
	     uiStage.act();
	     colide(); //COMPRUEBA CONDICIONES
	    
	    centrarCamaraRooms();
	    m3d.x = Gdx.input.getX();
	    m3d.y = Gdx.input.getY();
	    m3d.z = 0;
	    camara.unproject(m3d);
	    cursorX = m3d.x;
	    cursorY = m3d.y;
	    //actualizarInterfaz();
	    renderer.setView(camara);
	    renderer.render();
	    mainStage.getActors().sort(comparator);
        mainStage.draw();
        updateInterface();
        uiStage.draw();
	       
	}
	
	public void colide() {
		
		for(Enemies e: this.enemies) {
			if(e.getEnabled() && e.hp<=1 && Parametros.nivel == 205) {
				Parametros.erraticosKilled++;
			}
		}
		
		if(this.pomo200 != null) {
			if(this.pomo200.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E)) {
				if(!Parametros.key200) {
					AudioManager.playSound("audio/sounds/noAbre.mp3");
				} else {
					AudioManager.playSound("audio/sounds/doorOpens.mp3");
					Parametros.puerta = 0;
					Parametros.nivel = 200;
					game.setScreen(new GameScreen(game));
				}
				
			}
		}
		
		if(this.pomo204 != null) {
			if(this.pomo204.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E)) {
				if(!Parametros.key204) {
					AudioManager.playSound("audio/sounds/noAbre.mp3");
				} else {
					AudioManager.playSound("audio/sounds/doorOpens.mp3");
					AudioManager.playSound("audio/sounds/npcs/Bienvenida.mp3");
					Parametros.puerta = 0;
					Parametros.nivel = 204;
					Parametros.erraticosKilled = 0;
					game.setScreen(new GameScreen(game));
				}
			}
		}
		
		if(this.pomo224 != null) {
			if(this.pomo224.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E)) {
				if(!Parametros.key224) {
					AudioManager.playSound("audio/sounds/noAbre.mp3");
				} else if(!Parametros.angy && Parametros.key224) {
					AudioManager.playSound("audio/sounds/door224.mp3");
				} else {
					AudioManager.playSound("audio/sounds/doorOpens.mp3");
					Parametros.puerta = 0;
					Parametros.nivel = 224;
					game.setScreen(new GameScreen(game));
				}
			}
		}
		
		if(this.pomo231 != null) {
			if(this.pomo231.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E)) {
				if(!Parametros.key231) {
					AudioManager.playSound("audio/sounds/noAbre.mp3");
				} else {
					AudioManager.playSound("audio/sounds/doorOpens.mp3");
					Parametros.puerta = 0;
					Parametros.nivel = 231;
					game.setScreen(new GameScreen(game));
				}
				
			}
		}
		
		if(this.pomo243 != null) {
			if(this.pomo243.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E)) {
				if(!Parametros.key243) {
					AudioManager.playSound("audio/sounds/noAbre.mp3");
				} else {
					AudioManager.playSound("audio/sounds/doorOpens.mp3");
					Parametros.puerta = 0;
					Parametros.nivel = 243;
					game.setScreen(new GameScreen(game));
				}
				
			}
		}
		
		if(this.puzzleRoom != null) {
			if(this.puzzleRoom.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E)) {
				AudioManager.playSound("audio/sounds/npcs/YoQtu.mp3");
				Parametros.nivel = 205;
				game.setScreen(new GameScreen(game));
			}
		}
		
		if(this.pomo297 != null) {
			if(this.pomo297.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E) && Parametros.key297) {
				AudioManager.playSound("audio/sounds/doorOpens.mp3");
				Parametros.puerta = 0;
				Parametros.nivel = 297;
				game.setScreen(new GameScreen(game));
			} else if(this.pomo297.overlaps(this.player.sensor) && Gdx.input.isKeyJustPressed(Keys.E) && !Parametros.key297) {
				AudioManager.playSound("audio/sounds/noAbre.mp3");
			}
		}
		
		if(this.exitDoor1 != null) {
			if(Parametros.nivel == 297 && this.exitDoor1.overlaps(this.player) && Gdx.input.isKeyJustPressed(Keys.E)) {
				AudioManager.playSound("audio/sounds/doorOpens.mp3");
				Parametros.puerta = 297;
				backToFirstFloor();
			} else if(Parametros.nivel == 243 && this.exitDoor1.overlaps(this.player) && Gdx.input.isKeyJustPressed(Keys.E)) {
				AudioManager.playSound("audio/sounds/doorOpens.mp3");
				Parametros.puerta = 243;
				backToFirstFloor();
			} else if(Parametros.nivel == 224 && this.exitDoor1.overlaps(this.player) && Gdx.input.isKeyJustPressed(Keys.E)) {
				AudioManager.playSound("audio/sounds/doorOpens.mp3");
				Parametros.puerta = 224;
				backToFirstFloor();
			}
		}
		
		if(this.exitDoor2 != null) {
			if(Parametros.nivel == 200 && this.exitDoor2.overlaps(this.player) && Gdx.input.isKeyJustPressed(Keys.E)) {
				Parametros.puerta = 200;
				AudioManager.playSound("audio/sounds/noAbre.mp3");
			} else if(Parametros.nivel == 204 && this.exitDoor2.overlaps(this.player) && Gdx.input.isKeyJustPressed(Keys.E)) {
				AudioManager.playSound("audio/sounds/doorOpens.mp3");
				Parametros.puerta = 204;
				backToSecondFloor();
			} else if(Parametros.nivel == 231 && this.exitDoor2.overlaps(this.player) && Gdx.input.isKeyJustPressed(Keys.E)) {
				AudioManager.playSound("audio/sounds/doorOpens.mp3");
				Parametros.puerta = 231;
				backToSecondFloor();
			}
		}
		
		this.player.positionWheels();
		this.player.positionLasergun();
		this.player.positionSensor();
		
		if(Parametros.vida<=0) {
			game.setScreen(new DeathScreen(game));
			Parametros.vida = Parametros.maxVida;
		}
		
		if(this.player.win) {
			game.setScreen(new EndScreen(game));
			Parametros.vida = Parametros.maxVida;
			Parametros.nivel = 1;
			Parametros.puerta = 0;
			 
			Parametros.key200 = false;
			Parametros.key204 = false;
			Parametros.key224 = false;
			Parametros.key231 = false;
			Parametros.key243 = false;
			Parametros.key297 = false;
			 
			Parametros.bottleKitchen = false;
			Parametros.bottle204 = false;
			Parametros.bottle224 = false;
			Parametros.bottle231 = false;
			Parametros.bottle243 = false;
			Parametros.bottle297 = false;
			 
			Parametros.firstEnemyKey = false;
			Parametros.sunflower = false;
			Parametros.elevatorPuzzleSolved = false;
			Parametros.chestPuzzleSolved = false;
			Parametros.cats = false;
			Parametros.catsKey = false;
			Parametros.erraticosKilled = 0;
			 
			Parametros.angy = false;
			Parametros.ghostCompannion = ""; 
		}
		
		for(Solid s: solidos) {
			if(s.getEnabled() && s.overlaps(player)) {
				player.preventOverlap(s);
			}
		}
		
	}
	
	public void centrarCamara() {
		this.camara.position.x = MathUtils.clamp(player.getX(), this.camara.viewportWidth/1.5f, this.mapWidthPx-this.camara.viewportWidth/2);
		this.camara.position.y = MathUtils.clamp(player.getY(), this.camara.viewportHeight/2, this.mapHeightPx-this.camara.viewportHeight/2);
		camara.update();
		
	}
	
	public void centrarCamaraRooms() {
		this.camara.position.x = MathUtils.clamp(player.getX(), this.camara.viewportWidth/1.5f, this.mapWidthPx);
		this.camara.position.y = MathUtils.clamp(player.getY()+500, this.camara.viewportHeight/2, this.mapHeightPx);
		camara.update();
		
	}
	
